{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "NestJS Dev Server",
      "runtimeExecutable": "yarn",
      "runtimeArgs": ["start:dev"],
      "port": 3000
    },
    {
      "name": "Docker Compose (App + PostgreSQL)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up"],
      "port": 3000
    },
    {
      "name": "PostgreSQL (Docker only)",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "postgres"],
      "port": 5432
    }
  ]
}
